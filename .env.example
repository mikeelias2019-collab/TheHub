# Environment Variables for The Hub Real Estate Platform

# ===========================================
# MAP INTEGRATION API KEYS
# ===========================================

# Google Maps Platform (Recommended for full features)
# Get your key at: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox (Free tier available - 50K loads/month)
# Get your token at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# ===========================================
# MLS INTEGRATION API KEYS
# ===========================================

# California Regional MLS (CRMLS)
VITE_CRMLS_API_KEY=your_crmls_api_key_here
VITE_CRMLS_BASE_URL=https://api.crmls.org

# Bay East Association of Realtors (BEAR)
VITE_BEAR_API_KEY=your_bear_api_key_here
VITE_BEAR_BASE_URL=https://api.bayeast.org

# Houston Association of Realtors (HAR)
VITE_HAR_API_KEY=your_har_api_key_here
VITE_HAR_BASE_URL=https://api.har.com

# ===========================================
# ADDITIONAL REAL ESTATE APIs (OPTIONAL)
# ===========================================

# Zillow API (for additional market data)
VITE_ZILLOW_API_KEY=your_zillow_api_key_here

# Walk Score API (for walkability data)
VITE_WALK_SCORE_API_KEY=your_walk_score_api_key_here

# School Ratings API
VITE_SCHOOL_API_KEY=your_school_api_key_here

# ===========================================
# DATABASE & BACKEND
# ===========================================

# Supabase (Recommended for easy setup)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# DEPLOYMENT SETTINGS
# ===========================================

# Production URL
VITE_APP_URL=https://yourdomain.com

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=your_ga_tracking_id